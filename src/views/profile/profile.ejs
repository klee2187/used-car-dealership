<%- include("../partials/head", { title: "Profile", pageStyles: "profile" }) %>

    <%- include("../partials/header", { user }) %>
    <%- include("../partials/flash") %>

    <div class="profile-container">
        <h1>Welcome, <%= user.first_name %>!</h1>



        <div class="profile-info">
            <p><strong>First Name:</strong> <%= user.first_name %></p>
            <p><strong>Last Name:</strong> <%= user.last_name %></p>
            <p><strong>Username:</strong> <%= user.username %></p>
            <p><strong>Email:</strong> <%= user.email %></p>
            <p><strong>Role:</strong> <%= user.role %></p>
        </div>

        <div class="request-card">
            <h2>Your Service Requests</h2>
            <% if (serviceRequests.length > 0) { %>
                <ul class="service-requests">
                    <% serviceRequests.forEach(request => { %>
                        <li>
                            <strong><%= request.vehicle_make %> <%= request.vehicle_model %></strong> - <%= request.status %><br>
                            Submitted on: <%= new Date(request.created_at).toLocaleDateString() %><br>
                            Description: <%= request.description %>
                        </li>
                    <% }) %>
                </ul>
            <% } else { %>
                <p>You have no service requests.</p>
                <p>Need help? <a href="/vehicles">Browse vehicles and submit a service request</a>.</p>
            <% } %>
        </div>

        <div class="profile-update">

            <h2>Update Your Profile</h2>

            <form action="/profile" method="POST" class="form">

                <label for="first_name" class="form-label">First Name</label>
                <input type="text" name="first_name" id="first_name" value="<%= user.first_name %>" required>

                <label for="last_name" class="form-label">Last Name</label>
                <input type="text" name="last_name" id="last_name" value="<%= user.last_name %>" required>

                <label for="email" class="form-label">Email</label>
                <input type="email" name="email" id="email" value="<%= user.email %>" required>

                <button type="submit">Update Profile</button>
            </form>
        </div>

        <a href="/logout" class="logout-button">Logout</a>

    </div>

    <%- include("../partials/footer") %>
</body>
</html>