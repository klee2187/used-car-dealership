<%-include("../partials/head", { title: "Manage Users", pageStyles: "admin" })%>


<%- include("../partials/header") %>
<%- include("../partials/flash") %>

<div class="admin-users">

    <h1>View Users</h1>

    <table class="user-table">
        <thead>
            <tr>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Email</th>
                <th>Username</th>
                <th>Role</th>
            </tr>
        </thead>
        <tbody>
            <% users.forEach(user => { %>
                <tr>
                    <td><%= user.first_name %></td>
                    <td><%= user.last_name %></td>
                    <td><%= user.email %></td>
                    <td><%= user.username %></td>
                    <td><%= user.role %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<%- include("../partials/footer") %>
</body>
</html>