<%- include ("../partials/head", { title: `${vehicle.make} ${vehicle.model} Details`, pageStyles: "vehicle-detail" }) %>
<%- include("../partials/header") %>
<%- include("../partials/flash") %>

<div class="vehicle-detail-container">

    <h1><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></h1>

    <div class="vehicle-info">
        <p class="category">Category: <%=category ? category.name : "Uncategorized" %></p>
    </div>

    <div class="vehicle-image">
        <img src="<%= vehicle.image_url %>" alt="<%= vehicle.make %> <%= vehicle.model %>">
    </div>
    <div class="vehicle-main">
        <div class="vehicle-img">
            <% if (vehicle.image_url) { %>
                <img src="<%= vehicle.image_url %>" alt="<%= vehicle.make %> <%= vehicle.model %>">
            <% } %>
        </div>

        <div class="vehicle-info">
            <ul>
                <li><p><strong>Price:</strong> $<%= vehicle.price.toLocaleString() %></p></li>
                <li><p><strong>Mileage:</strong> <%= vehicle.mileage.toLocaleString() %> miles</p></li>
                <li><p><strong>Category:</strong> <%= category ? category.name : "Uncategorized" %></p></li>
                <li><p><strong>Availability:</strong> <%= vehicle.is_available ? "Available" : "Sold" %></p></li>
            </ul>

            <h3>Description</h3>
            <p><%= vehicle.description %></p>

            <a href="/vehicles/<%= vehicle.slug %>/edit" class="btn btn-primary">Back to Inventory</a>
        </div>
    </div>
    <div class="vehicle-reviews">
        <h2>Vehicle Reviews</h2>

        <% if (reviews && reviews.length > 0) { %>
            <p class="no-reviews">There are no reviews yet, but you can be the lucky one to leave one first.</p>
        <% } else { %>
            <p><a href="#review-form" class="btn btn-primary">Leave a Review</a></p>
        <% } %>

        <% reviews.forEach(review => { %>
            <div class="review-card">
                <div class="review-stars">
                    <% for (let i = 1; i <= 5; i++) { %>
                        <% if (i <= review.rating) { %>
                            <span class="star filled">&#9733;</span>
                        <% } else { %>
                            <span class="star">&#9733;</span>
                        <% } %>
                    <% } %>
                </div>

                <p class="reviewer"><strong><%= review.reviewer_name %></strong></p>
                <p class="review-date"><%= new Date(review.created_at).toLocaleDateString() %></p>
                <p class="review-comment"><%= review.comment %></p>
            </div>

    <a href="/serviceRequest/form/<%= vehicle.slug %>" class="btn btn-primary">Request Service</a>
    <a href="/reviews/form/<%= vehicle.vehicle_id %>" class="btn btn-secondary">View Reviews</a>
</div>

<%- include("../partials/footer") %>