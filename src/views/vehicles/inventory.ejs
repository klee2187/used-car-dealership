<%- include("../partials/head", { title: `${category.name} Vehicles`, pageStyles: "vehicles" }) %>
<%- include("../partials/header") %>

<div class="inventory-container">

    <h1><%= category.name %> Vehicles</h1>

    <% include("../partials/flash") %>

    <% if (vehicles && vehicles.length > 0) { %>
        <div class="vehicle-list">
            <ul class="vehicle-grid">
                <% vehicles.forEach(vehicle => { %>
                    <li class="vehicle-card">
                        <img src="<%= vehicle.image_url %>" alt="<%= vehicle.make %> <%= vehicle.model %>" class="vehicle-image">
                        <h3 class="vehicle-title"><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></h3>
                        <p class="vehicle-price">$<%= vehicle.price.toLocaleString() %></p>
                        <a href="/vehicles/<%= vehicle.slug %>">View Details</a>
                    </li>
                <% }); %>
            </ul>
        </div>

    <% } else { %>
        <p class="no-vehicles">No vehicles available in this category.</p>
    <% } %>

<%- include("../partials/footer") %>