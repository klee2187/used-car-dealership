<header class="site-header"> 
    <div class="container nav-wrap"> 
        <a class="logo" href="/"><img src="/images/auto-correct-logo.png" alt="Auto-Correct Motors Logo"></a> 
        <nav> 
            <a href="/">Home</a> 
            <a href="/about">About</a>
            <a href="/vehicles">Inventory</a> 
            <a href="/contact">Contact Us</a> 

            <!-- Show login/register links if not authenticated, otherwise show logout link -->
            <% if (locals.user) { %>
              <a href="/profile">Profile</a>
              <% if (locals.user.role === "admin") { %>
                <a href="/admin/dashboard">Admin Dashboard</a>
              <% } else if (locals.user.role === "employee") { %>
                <a href="/employee/dashboard">Employee Dashboard</a>
              <% } %>
              <a href="/logout">Logout</a>
            <% } else { %>
              <a href="/login">Login</a>
            <% } %>
        </nav> 
    </div> 
</header>