<%-include("../partials/head", { title: "Employee Messages", pageStyles: "admin" })%>
<%- include("../partials/header") %>
<%- include("../partials/flash") %>

<div class="admin-container">

    <h1>Customer Contact Messages</h1>

    <% if (messages.length === 0) { %>
        <p>No messages found.</p>
    <% } else { %>

        <table class="messages-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Subject</th>
                    <th>Message</th>
                    <th>Date Received</th>
                </tr>
            </thead>
            
            <tbody>
                <% messages.forEach(msg => { %>
                    <tr>
                        <td><%= msg.name %></td>
                        <td><%= msg.email %></td>
                        <td><%= msg.subject %></td>
                        <td><%= msg.message %></td>
                        <td><%= new Date(msg.created_at).toLocaleString() %></td>
                        <td>
                                <a href="mailto:<%= msg.email %>?subject=Re: <%= msg.subject %>" class="btn btn-primary btn-sm">Send Email</a>
                            </td>
                        <td>
                            <form action="/admin/messages/<%= msg.message_id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this message?');">
                                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } %>
</div>

<%- include("../partials/footer") %>